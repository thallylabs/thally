{
  "theme": "default",
  "banner": {
    "content": "This is a sample documentation site built with the Thally template. [Get started →](/quickstart)",
    "dismissible": true
  },
  "ai": {
    "chat": true,
    "label": "ThallyAI",
    "systemPrompt": "Prefer concise answers with links to relevant guide pages when available."
  },
  "admin": {
    "enabled": true
  },
  "analytics": {
    "enabled": true
  },
  "navbar": {
    "links": [
      {
        "label": "GitHub",
        "href": "https://github.com/thallylabs/thally",
        "type": "github"
      }
    ],
    "primary": {
      "label": "Get started",
      "href": "/quickstart"
    }
  },
  "footer": {
    "socials": {
      "github": "https://github.com/thallylabs/thally",
      "twitter": "https://twitter.com/thallydocs",
      "discord": "https://discord.gg/thally"
    },
    "links": [
      {
        "heading": "Documentation",
        "items": [
          {
            "label": "Quick Start",
            "href": "/quickstart"
          },
          {
            "label": "Guides",
            "href": "/guides/writing-content"
          },
          {
            "label": "Components",
            "href": "/components/badge"
          },
          {
            "label": "API Reference",
            "href": "/api"
          }
        ]
      },
      {
        "heading": "Customize",
        "items": [
          {
            "label": "Branding & Theming",
            "href": "/guides/branding-and-theming"
          },
          {
            "label": "Navbar & Footer",
            "href": "/guides/navbar-and-footer"
          },
          {
            "label": "Navigation",
            "href": "/guides/configuring-navigation"
          }
        ]
      },
      {
        "heading": "Tooling",
        "items": [
          {
            "label": "CLI Reference",
            "href": "/guides/cli-reference"
          },
          {
            "label": "MCP Server",
            "href": "/guides/mcp-server"
          },
          {
            "label": "AI & Agents",
            "href": "/guides/ai-features"
          }
        ]
      }
    ]
  },
  "feedback": {
    "thumbsRating": true,
    "endpoint": "/api/feedback"
  },
  "redirects": [
    {
      "source": "/docs",
      "destination": "/",
      "permanent": false
    },
    {
      "source": "/getting-started",
      "destination": "/quickstart",
      "permanent": true
    }
  ],
  "i18n": {
    "defaultLocale": "en",
    "locales": [
      {
        "code": "en",
        "label": "English"
      },
      {
        "code": "es",
        "label": "Español"
      }
    ]
  },
  "tabs": [
    {
      "tab": "Overview",
      "groups": [
        {
          "group": "Getting Started",
          "icon": "book-open",
          "pages": [
            "introduction",
            "quickstart"
          ]
        }
      ]
    },
    {
      "tab": "Guides",
      "groups": [
        {
          "group": "Content",
          "icon": "book-open",
          "pages": [
            "guides/writing-content",
            "guides/configuring-navigation",
            "guides/api-reference-setup"
          ]
        },
        {
          "group": "Customize",
          "icon": "grid-round",
          "pages": [
            "guides/branding-and-theming",
            "guides/custom-fonts",
            "guides/navbar-and-footer"
          ]
        },
        {
          "group": "Ship",
          "icon": "wrench",
          "pages": [
            "guides/deploying",
            "guides/admin-dashboard",
            "guides/seo-and-visibility"
          ]
        },
        {
          "group": "AI & Tooling",
          "icon": "code-simple",
          "pages": [
            "guides/ai-features",
            "guides/cli-reference",
            "guides/mcp-server",
            "guides/multi-language"
          ]
        }
      ]
    },
    {
      "tab": "API Reference",
      "groups": [
        {
          "group": "Overview",
          "pages": [
            "api/overview"
          ]
        }
      ],
      "api": {
        "source": "openapi.yaml",
        "tagsOrder": [
          "Posts",
          "Comments",
          "Users"
        ],
        "defaultGroup": "General",
        "overrides": {
          "GET /posts": {
            "title": "List posts",
            "description": "Fetch all posts, optionally filtered by author.",
            "badge": "Stable"
          },
          "POST /posts": {
            "title": "Create a post",
            "description": "Add a new post."
          },
          "GET /posts/{id}": {
            "title": "Get a post",
            "description": "Retrieve a single post by ID."
          },
          "DELETE /posts/{id}": {
            "title": "Delete a post",
            "description": "Remove a post.",
            "badge": "Destructive"
          }
        }
      }
    },
    {
      "tab": "Components",
      "groups": [
        {
          "group": "Content",
          "pages": [
            "components/badge",
            "components/callouts",
            "components/code-blocks",
            "components/panel",
            "components/update"
          ]
        },
        {
          "group": "Layout",
          "pages": [
            "components/accordion",
            "components/card",
            "components/columns",
            "components/frame",
            "components/steps",
            "components/tabs",
            "components/tile"
          ]
        },
        {
          "group": "Media & Diagrams",
          "pages": [
            "components/mermaid",
            "components/view",
            "components/color"
          ]
        },
        {
          "group": "API Reference",
          "pages": [
            "components/param-field",
            "components/response-field",
            "components/expandable",
            "components/request-response-example"
          ]
        },
        {
          "group": "Navigation",
          "pages": [
            "components/file-tree",
            "components/tooltip",
            "components/prompt"
          ]
        }
      ]
    },
    {
      "tab": "Changelog",
      "href": "/changelog"
    }
  ]
}
