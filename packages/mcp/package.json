{
  "name": "@thallylabs/mcp",
  "version": "0.7.3",
  "description": "MCP server for scaffolding and managing Thally documentation projects",
  "type": "module",
  "engines": {
    "node": ">=18"
  },
  "bin": {
    "thally-mcp": "./dist/index.js"
  },
  "exports": {
    ".": "./dist/index.js",
    "./tools": {
      "types": "./dist/tools.d.ts",
      "import": "./dist/tools.js"
    },
    "./package.json": "./package.json",
    "./track": {
      "types": "./dist/track.d.ts",
      "import": "./dist/track.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.36.0",
    "@modelcontextprotocol/sdk": "^1.15.0",
    "create-thally-docs": "0.7.7",
    "gray-matter": "^4.0.3",
    "p-limit": "^6.1.0",
    "tar": "^6.2.0",
    "zod": "^3.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/tar": "^6.1.13",
    "tsup": "^8.0.0",
    "typescript": "^5.0.0"
  },
  "license": "MIT",
  "keywords": [
    "thally",
    "documentation",
    "mcp",
    "model-context-protocol",
    "ai",
    "agent",
    "claude",
    "cursor",
    "llm"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/thallylabs/thally.git",
    "directory": "packages/mcp"
  },
  "homepage": "https://github.com/thallylabs/thally#readme",
  "bugs": {
    "url": "https://github.com/thallylabs/thally/issues"
  }
}
