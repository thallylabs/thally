{
  "name": "@thallylabs/cli",
  "version": "0.5.3",
  "description": "The unified thally CLI — author content + config; the framework stays a hidden runtime",
  "type": "module",
  "engines": {
    "node": ">=18"
  },
  "bin": {
    "thally": "./dist/index.js"
  },
  "exports": {
    ".": "./dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "create-thally-docs": "0.7.5",
    "@thallylabs/mcp": "0.7.1",
    "@anthropic-ai/sdk": "^0.78.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.0.0",
    "vitest": "^4.0.15",
    "@thallylabs/agent": "*"
  },
  "license": "MIT",
  "keywords": [
    "thally",
    "documentation",
    "docs",
    "cli",
    "mdx",
    "nextjs",
    "ai",
    "agent-native"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/thallylabs/thally.git",
    "directory": "packages/cli"
  },
  "homepage": "https://github.com/thallylabs/thally#readme",
  "bugs": {
    "url": "https://github.com/thallylabs/thally/issues"
  }
}
