{
  "name": "@thallylabs/agent",
  "version": "0.3.0",
  "description": "Thally's review-gated agent for turning product changes into evidence-backed documentation pull requests.",
  "type": "module",
  "engines": {
    "node": ">=18"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./scaffold": {
      "types": "./dist/scaffold.d.ts",
      "import": "./dist/scaffold.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.78.0",
    "@thallylabs/mcp": "*",
    "create-thally-docs": "*",
    "zod-to-json-schema": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.0.0",
    "zod": "^3.0.0"
  },
  "license": "MIT",
  "keywords": [
    "thally",
    "documentation",
    "agent",
    "ai",
    "claude",
    "docs-as-code"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/thallylabs/thally.git",
    "directory": "packages/agent"
  },
  "private": true
}
