{
  "name": "@thallylabs/migrate",
  "version": "0.1.2",
  "description": "Shared repository and live-site migration engine for Thally",
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=18"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "cheerio": "1.0.0",
    "gray-matter": "^4.0.3",
    "turndown": "^7.2.1",
    "yaml": "^2.6.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/turndown": "^5.0.5",
    "tsup": "^8.0.0",
    "typescript": "^5.0.0",
    "vitest": "^4.0.15"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/thallylabs/thally.git",
    "directory": "packages/migrate"
  }
}
