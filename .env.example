# Thally environment variables (copy to .env.local)
#
# Legacy DOX_* names still work: every THALLY_* variable falls back to its
# old DOX_* equivalent, so existing deployments keep working unchanged.

# Site URL (required for production). Framework-agnostic — you never need to
# know what runs underneath. The legacy NEXT_PUBLIC_SITE_URL is still honored.
THALLY_SITE_URL=http://localhost:3040

# Thally Cloud (optional). Paste the one-time site credential from Thally Cloud into
# your hosting provider as a SERVER-SIDE secret, then redeploy. Never prefix it
# with NEXT_PUBLIC_. The runtime exchanges it for short-lived grants and phones
# home automatically when the deployed docs site is visited.
# THALLY_CLOUD_SITE_TOKEN=thally_site_...
# THALLY_CLOUD_URL=https://app.thally.io

# Optional: opt out of Turbopack's persistent build cache (kept under
# .next/cache; speeds up warm builds). Set only if a production build
# misbehaves with the cache enabled.
# THALLY_DISABLE_BUILD_CACHE=1

# Admin dashboard — set to enable /admin analytics
THALLY_ADMIN_PASSWORD=change-me

# Optional: separate signing secret (defaults to admin password)
# THALLY_ADMIN_SECRET=

# Optional: password-protect the entire docs site
# THALLY_ACCESS_PASSWORD=

# Optional: internal analytics ingest secret
# THALLY_ANALYTICS_SECRET=

# Analytics store (durable, serverless-safe). Defaults to an embedded libSQL file
# at .data/analytics/events.db — zero config, no external service for local/self-host.
# For production on serverless (Vercel/Lambda), point at a Turso/libSQL database so
# events survive redeploys and are shared across instances:
# THALLY_ANALYTICS_DB_URL=libsql://your-db.turso.io
# THALLY_ANALYTICS_DB_TOKEN=your-turso-auth-token

# Durable key–value storage (rate-limit counters, docs-task queue, insights, audit).
# Defaults to an embedded libSQL file at .data/thally.db — zero config for local/self-host.
# For production on serverless, point at a Turso/libSQL database so state survives
# redeploys and is shared across instances. Set THALLY_STORAGE=memory to opt out entirely.
# THALLY_DATABASE_URL=libsql://your-db.turso.io
# THALLY_DATABASE_TOKEN=your-turso-auth-token
# THALLY_STORAGE=memory

# AI chat widget
# Owner key — set this for production. Lifts trial limits entirely.
# ANTHROPIC_API_KEY=

# Optional shared "trial" key for the out-of-the-box aha experience. When
# ANTHROPIC_API_KEY is unset, chat falls back to this key under strict caps.
# Give it a hard spend cap in your Anthropic account.
# THALLY_TRIAL_ANTHROPIC_KEY=

# Optional rate-limit overrides (per IP unless noted):
# THALLY_CHAT_RATE_PER_MIN=20      # owner tier, requests/min
# THALLY_CHAT_RATE_PER_DAY=0       # owner tier, requests/day (0 = unlimited)
# THALLY_TRIAL_RATE_PER_MIN=5      # trial tier, requests/min
# THALLY_TRIAL_RATE_PER_DAY=30     # trial tier, requests/day
# THALLY_TRIAL_DAILY_LIMIT=500     # trial tier, global requests/day across all IPs

# Admin team auth (C1) — the session-signing secret (a secret, NOT a database).
# Required to enable team accounts + roles; without it, the admin falls back to
# the single THALLY_ADMIN_PASSWORD. Use a long random string.
# THALLY_AUTH_SECRET=change-me-to-a-long-random-string

# Thally Track — merged/preview PRs in tracked repos become docs PRs (see /guides/thally-track).
#
# Recommended: use the admin dashboard "Connect GitHub" button (Settings →
# Integrations) to create + install your own GitHub App — no env vars, org-wide
# access to selected repos. That path only needs THALLY_AUTH_SECRET (above) set.
#
# Dispatch target — the docs repo Track opens PRs against. Defaults to
# siteConfig.repoUrl (site.ts). Set this when you keep site.ts as the template
# default (repoUrl: '') but still want Track to dispatch to your own repo, e.g.
# the canonical Thally deployment. Deployer-set, so it's trusted (unlike the
# admin-editable repo URL, which the webhook intentionally ignores).
# THALLY_REPO_URL=https://github.com/your-org/your-docs-repo

# Manual webhook path (Mode B): HMAC secret shared with the GitHub webhook on
# each tracked repo; /api/track/webhook is OFF until this is set (a connected
# GitHub App supplies its own secret and doesn't need this).
# THALLY_TRACK_WEBHOOK_SECRET=

# GitHub token (Mode B): a fine-grained PAT that reads tracked product-repo PRs,
# relays the dispatch to the docs repo, and authenticates the admin Docs-tasks
# queue. Public repos work without it (rate-limited).
# THALLY_GITHUB_TOKEN=

# Optional — wire a GitHub App by hand instead of the Connect button. The token
# resolver mints an installation token from these (private key is the PEM).
# THALLY_GITHUB_APP_ID=
# THALLY_GITHUB_APP_INSTALLATION_ID=
# THALLY_GITHUB_APP_PRIVATE_KEY=
