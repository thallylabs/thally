# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem
.data/

# dox generated artifacts (embeddings cache, analytics)
.dox/
.data/

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

.next
.out
# Workspace package build output — generated by `packages:build` (which the app's
# prebuild runs) and by `prepublishOnly` at npm-publish time, so it needn't be committed.
packages/*/dist

# Local agent/tooling state + scratch — not part of the product, never committed.
.claude/
.agents/
skills-lock.json
CLAUDE.md

# Local demo scaffolds (other projects generated for testing).
demo/

# Personal/process notes. The shared notes/*.md (design-system, product-principles)
# stay tracked; these are local planning + the history-scrub handoff (must never ship).
notes/auth-model.md
notes/dox-v2-plan.md
notes/dox-v2-updated-plan.md
notes/mintlify-audit.md
notes/worktree-history-scrub-handoff.md
